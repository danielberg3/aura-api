generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model News {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  content     String
  publishedAt DateTime
  createdAt   DateTime @default(now())
}

model User {
  id String @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  birthdate DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  exams     Exam[]
}

model Exam {
  id              String    @id @default(uuid())
  examName        String
  examDate        DateTime
  examDescription String
  examImage       String
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

